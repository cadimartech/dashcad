# DashCAD — copia a .env y ajusta según tu entorno
#
# Layout por defecto (desarrollo local sin Docker):
#   ./data/catalog/parts.json   -> metadata (DASHCAD_DATA_PATH)
#   ./data/files/{step,glb,thumb} -> binarios (DASHCAD_FILES_PATH)
#
# En Docker los paths del host se montan en /app/catalog y /app/files
# respectivamente, y DASHCAD_FILES_PATH=/app/files se define en el compose.

NODE_ENV=production

# Puerto expuesto en el host (default: 3000)
DASHCAD_PORT=3000

# Carpeta local donde se guarda SOLO el JSON del catálogo (parts.json).
# En NAS suele ser una ruta absoluta, p. ej.
#   /ZimaOS-HD/AppData/dashcad/data/catalog
DASHCAD_DATA_PATH=./data/catalog

# Ruta del JSON del catálogo dentro del contenedor (opcional).
# Si no se define, usa <DASHCAD_DATA_PATH>/parts.json
# DASHCAD_CATALOG_PATH=/app/catalog/parts.json

# Carpeta donde se guardan los archivos binarios (STEP, GLB, thumbnails).
# Mantenla separada de DASHCAD_DATA_PATH para poder montarla en otro disco,
# volumen o servicio de almacenamiento. Si no se define, la app usa
# <DASHCAD_DATA_PATH> (comportamiento retrocompatible con instalaciones
# anteriores donde todo vivía bajo ./catalog).
# En NAS: /storage/cad
DASHCAD_FILES_PATH=./data/files

# Tamaño máximo de upload en bytes (opcional, default: 50 MiB)
# MAX_UPLOAD_SIZE=52428800
