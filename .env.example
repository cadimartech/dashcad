# DashCAD — copia a .env y ajusta según tu entorno

NODE_ENV=production

# Puerto expuesto en el host (default: 3000)
DASHCAD_PORT=3000

# Carpeta local donde se guarda SOLO el JSON del catálogo (parts.json).
# En NAS suele ser una ruta absoluta, p. ej. /volume1/docker/dashcad/data/catalog
DASHCAD_DATA_PATH=./data/catalog

# Ruta del JSON del catálogo dentro del contenedor (opcional)
# DASHCAD_CATALOG_PATH=/app/catalog/parts.json

# Carpeta local donde se guardan los archivos binarios (STEP, GLB, thumbnails).
# Mantenla separada de DASHCAD_DATA_PATH para poder montarla en otro disco,
# volumen o servicio de almacenamiento. Si no se define, cae en <DASHCAD_DATA_PATH>
# (comportamiento retrocompatible con instalaciones anteriores).
# En NAS, por ejemplo: /volume1/docker/dashcad/data/files
# DASHCAD_FILES_PATH=./data/files

# Tamaño máximo de upload en bytes (opcional, default: 10MB)
# MAX_UPLOAD_SIZE=10485760
